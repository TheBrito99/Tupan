{
  "name": "tupan",
  "version": "0.1.0",
  "description": "Comprehensive mechatronics engineering platform with multi-domain simulators",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev": "pnpm -r dev",
    "wasm:build": "cd packages/core-rust && wasm-pack build --target web --release",
    "wasm:dev": "cd packages/core-rust && wasm-pack build --target web",
    "wasm:clean": "rm -rf packages/core-rust/pkg",
    "tauri": "cargo tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "pnpm wasm:build && cargo tauri build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.0"
    }
  },
  "dependencies": {
    "uuid": "^9.0.0"
  }
}
